# 获得所有默认配置项
# ghostty +show-config --default
# ghostty +show-config --default --docs

# 每一项的详细解释可以看
# https://ghostty.org/docs/config/reference

# 主题、颜色
# https://ghostty.org/docs/features/theme
# ll /Applications/Ghostty.app/Contents/Resources/ghostty/themes
window-theme = system
# theme = light:Monokai Pro Light,dark:Monokai Pro Machine
theme = light:Catppuccin Latte,dark:Catppuccin Frappe
# theme = light:Gruvbox Light,dark:Gruvbox Dark
# theme = light:TokyoNight Day,dark:TokyoNight Moon

bold-color = bright
faint-opacity = 0.7

# 样式
adjust-underline-position = 20%
adjust-underline-thickness = 30%
adjust-cursor-height = -50%
adjust-cursor-thickness = +150%

# 更多鼠标光标样式
cursor-click-to-move = true
mouse-hide-while-typing = true

# 字体

font-family = "JetBrains Maple Mono"
# font-family = "Google Sans Code"
# font-family = "Cascadia Mono"
# font-family = "0xProto"
# font-family = "Noto Sans Mono"
# font-family = "Reddit Mono"
# font-family = "JetBrains Mono"

## Monaspace Neon
# font-family = "Monaspace Neon"
# font-family-italic = "IBM Plex Mono Light Italic"
# font-family-bold = "IBM Plex Mono SemiBold"
# font-family-bold-italic = "IBM Plex Mono SemiBold Italic"

## IBM Plex Mono
# font-family = "IBM Plex Mono Regular"
# font-family-italic = "IBM Plex Mono Italic"
# font-family-bold = "IBM Plex Mono Bold"
# font-family-bold-italic = "IBM Plex Mono Bold Italic"


font-size = 11.5
font-feature = -calt, -liga, -dlig
adjust-cell-height = 10%

# 默认字体比较细
font-thicken = true
font-thicken-strength = 80

font-synthetic-style = "bold,italic,bold-italic"

# 更新策略
auto-update = check
auto-update-channel = stable

# 回滚
# 单位byte，设置成1G = 1024 * 1024 * 1024 = 1073741824
scrollback-limit = 1073741824
scroll-to-bottom = keystroke, output
mouse-scroll-multiplier = precision:3,discrete:10

# 设置Quick Terminal位置和快捷键
quick-terminal-position = center
keybind = global:cmd+grave_accent=toggle_quick_terminal

# 窗口设置
window-height = 35
window-width = 160
window-save-state = always
window-new-tab-position = end

background-opacity = 0.96
background-blur = 25

# macOS特有
macos-window-buttons = visible
macos-titlebar-style = tabs
macos-titlebar-proxy-icon = visible

# macOS图标样式
# 在offical和其他内置主题切换时，需要重启Ghostty
macos-icon = official

# 自定义macOS图标样式
# macos-icon = custom-style
# macos-icon-frame = chrome
# macos-icon-ghost-color = #FF2600
# macos-icon-screen-color = #0053FA

# 窗口间距
window-padding-y = 2,4
window-padding-x = 4,4
window-padding-balance = true

# 鼠标样式
cursor-style = block
cursor-color = "#FF2600"
cursor-text = "#FA2600"

# 剪贴板
clipboard-read = allow
clipboard-write = allow
# false表示用自动剪贴板，true表示用选择剪贴板
copy-on-select = false
clipboard-trim-trailing-spaces = false
right-click-action = copy-or-paste

# Splits
unfocused-split-opacity = 0.8
unfocused-split-fill = "#fac400"
split-divider-color = "#7a7a7a"

