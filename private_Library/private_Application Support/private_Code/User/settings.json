{
    "[css]": {
        "editor.defaultFormatter": "vscode.css-language-features"
    },
    "[html]": {
        "editor.defaultFormatter": "vscode.html-language-features"
    },
    "[json]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "[perl]": {
        "editor.detectIndentation": false,
        "editor.insertSpaces": true,
        "editor.tabSize": 4,
        "editor.useTabStops": true
    },
    "[python]": {
        "editor.formatOnType": true
    },
    "[typescriptreact]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "accessibility.signals.taskCompleted": {
        "sound": "on"
    },
    "accessibility.signals.taskFailed": {
        "sound": "on"
    },
    "accessibility.signals.terminalBell": {
        "sound": "on"
    },
    "chat.agent.enabled": false,
    "chat.fontSize": 11,
    "debug.confirmOnExit": "always",
    "debug.console.fontSize": 10,
    "debug.terminal.clearBeforeReusing": true,
    "diffEditor.ignoreTrimWhitespace": false,
    "editor.accessibilitySupport": "off",
    "editor.autoIndentOnPaste": true,
    "editor.codeLensFontFamily": "'Monaspace Neon', 'SF Mono'",
    "editor.cursorBlinking": "smooth",
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.cursorStyle": "line",
    "editor.cursorSurroundingLines": 3,
    "editor.cursorSurroundingLinesStyle": "all",
    "editor.cursorWidth": 3,
    "editor.defaultColorDecorators": "auto",
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.dragAndDrop": false,
    "editor.experimental.asyncTokenization": true,
    "editor.experimental.asyncTokenizationLogging": true,
    "editor.experimental.asyncTokenizationVerification": true,
    "editor.fontFamily": "'Monaspace Neon', 'SF Mono'",
    "editor.fontLigatures": false,
    "editor.fontWeight": "normal",
    "editor.formatOnType": true,
    "editor.glyphMargin": false,
    "editor.inlayHints.fontFamily": "default",
    "editor.lineHeight": 1.7,
    "editor.minimap.enabled": false,
    "editor.padding.bottom": 10,
    "editor.padding.top": 10,
    "editor.renderLineHighlight": "all",
    "editor.renderLineHighlightOnlyWhenFocus": true,
    "editor.renderWhitespace": "all",
    "editor.roundedSelection": false,
    "editor.scrollBeyondLastLine": false,
    "editor.suggest.preview": true,
    "editor.tabCompletion": "on",
    "editor.tokenColorCustomizations": {
        "[Atom One Dark]": {
            "comments": {
                "fontStyle": "",
                "foreground": "#519d58"
            }
        },
        "[Atom One Light]": {
            "comments": {
                "fontStyle": "",
                "foreground": "#e99120"
            }
        }
    },
    "editor.unicodeHighlight.ambiguousCharacters": false,
    "editor.unicodeHighlight.includeComments": true,
    "editor.unicodeHighlight.invisibleCharacters": false,
    "editor.unicodeHighlight.nonBasicASCII": false,
    "editor.wordWrap": "on",
    "evenBetterToml.formatter.indentEntries": true,
    "explorer.compactFolders": false,
    "explorer.confirmDragAndDrop": false,
    "explorer.copyRelativePathSeparator": "/",
    "explorer.fileNesting.enabled": true,
    "explorer.incrementalNaming": "smart",
    "explorer.openEditors.minVisible": 1,
    "files.autoGuessEncoding": true,
    "files.autoSave": "afterDelay",
    "files.restoreUndoStack": false,
    "files.trimTrailingWhitespace": true,
    "git.closeDiffOnOperation": true,
    "git.confirmSync": false,
    "git.ignoreRebaseWarning": true,
    "interactiveWindow.collapseCellInputCode": "never",
    "interactiveWindow.executeWithShiftEnter": true,
    "interactiveWindow.promptToSaveOnClose": true,
    "interactiveWindow.showExecutionHint": false,
    "js/ts.implicitProjectConfig.checkJs": true,
    "jupyter.askForKernelRestart": false,
    "jupyter.disableJupyterAutoStart": true,
    "jupyter.enableExtendedPythonKernelCompletions": true,
    "jupyter.exportWithOutputEnabled": true,
    "jupyter.interactiveWindow.textEditor.magicCommandsAsComments": true,
    "jupyter.logKernelOutputSeparately": true,
    "markdown-preview-github-styles.colorTheme": "system",
    "markdown.preview.fontSize": 12,
    "markdown.preview.lineHeight": 1.2,
    "markdown.preview.markEditorSelection": false,
    "notebook.breadcrumbs.showCodeCells": false,
    "notebook.cellExecutionTimeVerbosity": "verbose",
    "notebook.cellToolbarLocation": {
        "default": "left",
        "jupyter-notebook": "left"
    },
    "notebook.compactView": false,
    "notebook.consolidatedRunButton": true,
    "notebook.defaultFormatter": "charliermarsh.ruff",
    "notebook.dragAndDropEnabled": false,
    "notebook.editorOptionsCustomizations": {},
    "notebook.experimental.generate": false,
    "notebook.lineNumbers": "on",
    "notebook.markdown.lineHeight": 30,
    "notebook.markup.fontSize": 13,
    "notebook.multiCursor.enabled": true,
    "notebook.outline.showCodeCells": true,
    "notebook.output.fontFamily": "'Monaspace Neon', 'SF Mono'",
    "notebook.output.fontSize": 10,
    "notebook.output.minimalErrorRendering": true,
    "notebook.output.scrolling": true,
    "notebook.output.textLineLimit": 500,
    "notebook.output.wordWrap": true,
    "notebook.stickyScroll.enabled": true,
    "php.validate.executablePath": "/usr/local/bin/php",
    "prettier.printWidth": 120,
    "prettier.tabWidth": 4,
    "python.createEnvironment.trigger": "off",
    "python.defaultInterpreterPath": "/usr/local/bin/python3",
    "python.globalModuleInstallation": true,
    "python.languageServer": "Pylance",
    "python.terminal.activateEnvInCurrentTerminal": true,
    "python.terminal.useEnvFile": true,
    "scm.alwaysShowRepositories": true,
    "scm.compactFolders": false,
    "scm.inputFontSize": 11,
    "scm.providerCountBadge": "visible",
    "search.defaultViewMode": "tree",
    "search.globalFindClipboard": true,
    "search.searchEditor.reusePriorSearchConfiguration": true,
    "search.showLineNumbers": true,
    "security.workspace.trust.enabled": false,
    "security.workspace.trust.untrustedFiles": "open",
    "svelte.enable-ts-plugin": true,
    "terminal.integrated.bellDuration": 600,
    "terminal.integrated.confirmOnExit": "hasChildProcesses",
    "terminal.integrated.copyOnSelection": true,
    "terminal.integrated.cursorBlinking": true,
    "terminal.integrated.cursorStyle": "line",
    "terminal.integrated.cursorStyleInactive": "line",
    "terminal.integrated.cursorWidth": 3,
    "terminal.integrated.defaultProfile.osx": "zsh",
    "terminal.integrated.enableFileLinks": "notRemote",
    "terminal.integrated.enablePersistentSessions": false,
    "terminal.integrated.focusAfterRun": "terminal",
    "terminal.integrated.fontFamily": "'Monaspace Neon', 'SF Mono'",
    "terminal.integrated.fontLigatures.featureSettings": "\"calt\" off, \"liga\" off",
    "terminal.integrated.fontWeightBold": "normal",
    "terminal.integrated.gpuAcceleration": "on",
    "terminal.integrated.hideOnStartup": "whenEmpty",
    "terminal.integrated.ignoreBracketedPasteMode": true,
    "terminal.integrated.inheritEnv": false,
    "terminal.integrated.initialHint": false,
    "terminal.integrated.letterSpacing": 0.5,
    "terminal.integrated.lineHeight": 1.7,
    "terminal.integrated.localEchoStyle": "dim",
    "terminal.integrated.minimumContrastRatio": 7,
    "terminal.integrated.mouseWheelScrollSensitivity": 5,
    "terminal.integrated.rightClickBehavior": "nothing",
    "terminal.integrated.scrollback": 10000000,
    "terminal.integrated.shellIntegration.enabled": true,
    "terminal.integrated.shellIntegration.environmentReporting": true,
    "terminal.integrated.shellIntegration.history": 100000000,
    "terminal.integrated.smoothScrolling": true,
    "terminal.integrated.splitCwd": "workspaceRoot",
    "terminal.integrated.suggest.cdPath": "relative",
    "terminal.integrated.suggest.inlineSuggestion": "alwaysOnTopExceptExactMatch",
    "terminal.integrated.suggest.insertTrailingSpace": true,
    "terminal.integrated.suggest.providers": {
        "lsp": true,
        "vscode.terminal-suggest": false
    },
    "terminal.integrated.suggest.runOnEnter": "exactMatchIgnoreExtension",
    "terminal.integrated.suggest.suggestOnTriggerCharacters": true,
    "terminal.integrated.tabs.focusMode": "singleClick",
    "terminal.integrated.tabs.hideCondition": "singleGroup",
    "terminal.integrated.tabs.separator": "|",
    "terminal.integrated.tabStopWidth": 4,
    "terminal.integrated.unicodeVersion": "11",
    "terminal.integrated.useWslProfiles": false,
    "todo-tree.general.tags": [
        "BUG",
        "HACK",
        "FIXME",
        "TODO",
        "XXX",
        "[ ]",
        "[x]",
        "MARK",
        "NOTE"
    ],
    "todo-tree.highlights.useColourScheme": true,
    "todo-tree.tree.showCountsInTree": true,
    "vim.disableExtension": true,
    "window.autoDetectColorScheme": true,
    "window.commandCenter": false,
    "window.nativeTabs": true,
    "window.newWindowDimensions": "offset",
    "window.newWindowProfile": "Default",
    "window.openFoldersInNewWindow": "on",
    "window.systemColorTheme": "auto",
    "window.titleBarStyle": "native",
    "workbench.activityBar.compact": true,
    "workbench.colorCustomizations": {
        "[Atom One Dark]": {
            "editor.lineHighlightBackground": "#484c51",
            "editor.selectionBackground": "#4a4a4a"
        },
        "[Atom One Light]": {
            "editor.lineHighlightBackground": "#d1e8ff",
            "editor.selectionBackground": "#c6daed"
        }
    },
    "workbench.colorTheme": "Monokai",
    "workbench.editor.closeOnFileDelete": true,
    "workbench.editor.dragToOpenWindow": false,
    "workbench.editor.enablePreviewFromCodeNavigation": true,
    "workbench.editor.enablePreviewFromQuickOpen": true,
    "workbench.editor.highlightModifiedTabs": true,
    "workbench.editor.pinnedTabSizing": "shrink",
    "workbench.editor.restoreViewState": false,
    "workbench.editor.revealIfOpen": true,
    "workbench.iconTheme": "vscode-icons-mac",
    "workbench.layoutControl.enabled": false,
    "workbench.settings.alwaysShowAdvancedSettings": true,
    "workbench.settings.enableNaturalLanguageSearch": false,
    "workbench.sideBar.location": "right",
    "workbench.view.alwaysShowHeaderActions": true
}